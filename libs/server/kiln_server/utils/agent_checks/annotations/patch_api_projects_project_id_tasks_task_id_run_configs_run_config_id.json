{
  "method": "patch",
  "path": "/api/projects/{project_id}/tasks/{task_id}/run_configs/{run_config_id}",
  "agent_policy": {
    "permission": "allow",
    "requires_approval": true,
    "approval_description": "Allow agent to edit run config? Ensure you backup your project before allowing agentic edits."
  },
  "request_body": {
    "required": true,
    "content_type": "application/json",
    "schema": {
      "properties": {
        "name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Name",
          "description": "The updated name."
        },
        "starred": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "title": "Starred",
          "description": "The updated starred status."
        },
        "prompt_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Prompt Name",
          "description": "The updated prompt name."
        }
      },
      "type": "object",
      "title": "UpdateRunConfigRequest",
      "description": "Request to update a run config."
    }
  },
  "parameters": {
    "path": {
      "project_id": {
        "type": "string",
        "description": "The unique identifier of the project.",
        "title": "Project Id"
      },
      "task_id": {
        "type": "string",
        "description": "The unique identifier of the task within the project.",
        "title": "Task Id"
      },
      "run_config_id": {
        "type": "string",
        "description": "The unique identifier of the run configuration.",
        "title": "Run Config Id"
      }
    },
    "query": {}
  }
}
