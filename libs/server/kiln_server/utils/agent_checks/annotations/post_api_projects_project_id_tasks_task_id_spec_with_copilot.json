{
  "method": "post",
  "path": "/api/projects/{project_id}/tasks/{task_id}/spec_with_copilot",
  "agent_policy": {
    "permission": "allow",
    "requires_approval": true,
    "approval_description": "Create spec with Copilot?"
  },
  "request_body": {
    "required": true,
    "content_type": "application/json",
