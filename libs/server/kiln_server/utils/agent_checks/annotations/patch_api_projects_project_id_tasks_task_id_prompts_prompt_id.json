{
  "method": "patch",
  "path": "/api/projects/{project_id}/tasks/{task_id}/prompts/{prompt_id}",
  "agent_policy": {
    "permission": "allow",
    "requires_approval": true,
    "approval_description": "Allow agent to edit prompt? Ensure you backup your project before allowing agentic edits."
  },
  "request_body": {
    "required": true,
    "content_type": "application/json",
    "schema": {
      "properties": {
        "name": {
          "type": "string",
          "title": "Name",
          "description": "The updated name."
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Description",
          "description": "The updated description."
        }
      },
      "type": "object",
      "required": [
        "name"
      ],
      "title": "PromptUpdateRequest",
      "description": "Request to update a prompt."
    }
  },
  "parameters": {
    "path": {
      "project_id": {
        "type": "string",
        "description": "The unique identifier of the project.",
        "title": "Project Id"
      },
      "task_id": {
        "type": "string",
        "description": "The unique identifier of the task within the project.",
        "title": "Task Id"
      },
      "prompt_id": {
        "type": "string",
        "description": "The unique identifier of the prompt.",
        "title": "Prompt Id"
      }
    },
    "query": {}
  }
}
