{
  "method": "patch",
  "path": "/api/projects/{project_id}/rag_configs/{rag_config_id}",
  "agent_policy": {
    "permission": "allow",
    "requires_approval": true,
    "approval_description": "Allow agent to edit RAG config? Ensure you backup your project before allowing agentic edits."
  },
  "request_body": {
    "required": true,
    "content_type": "application/json",
    "schema": {
      "properties": {
        "name": {
          "anyOf": [
            {
              "type": "string",
              "maxLength": 120,
              "minLength": 1
            },
            {
              "type": "null"
            }
          ],
          "title": "Name",
          "description": "The updated name."
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Description",
          "description": "The updated description."
        },
        "is_archived": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "title": "Is Archived",
          "description": "Whether the config is archived."
        }
      },
      "type": "object",
      "title": "UpdateRagConfigRequest",
      "description": "Request to update a RAG config."
    }
  },
  "parameters": {
    "path": {
      "project_id": {
        "type": "string",
        "description": "The unique identifier of the project.",
        "title": "Project Id"
      },
      "rag_config_id": {
        "type": "string",
        "description": "The unique identifier of the RAG configuration.",
        "title": "Rag Config Id"
      }
    },
    "query": {}
  }
}
