              }
            },
            {
              "type": "null"
            }
          ],
          "title": "Properties",
          "description": "The updated spec properties."
        },
        "priority": {
          "anyOf": [
            {
              "type": "integer",
              "enum": [
                0,
                1,
                2,
                3
              ],
              "title": "Priority",
              "description": "Priority levels, where P0 is highest priority."
            },
            {
              "type": "null"
            }
          ],
          "description": "The updated priority."
        },
        "status": {
          "anyOf": [
            {
              "type": "string",
              "enum": [
                "active",
                "future",
                "deprecated",
                "archived"
              ],
              "title": "SpecStatus",
              "description": "Defines the status of a spec."
            },
            {
              "type": "null"
            }
          ],
          "description": "The updated status."
        },
        "tags": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "title": "Tags",
          "description": "The updated tags."
        }
