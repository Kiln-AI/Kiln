                    },
                    "unacceptable_examples": {
                      "type": "string",
                      "title": "Unacceptable Examples"
                    }
                  },
                  "type": "object",
                  "required": [
                    "spec_type",
                    "core_requirement",
                    "tone_description"
                  ],
                  "title": "ToneProperties"
                },
                {
                  "properties": {
                    "spec_type": {
                      "type": "string",
