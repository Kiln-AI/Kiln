  "parameters": {
    "path": {
      "project_id": {
        "type": "string",
        "description": "The unique identifier of the project.",
        "title": "Project Id"
      },
      "task_id": {
        "type": "string",
        "description": "The unique identifier of the task within the project.",
        "title": "Task Id"
      },
      "spec_id": {
        "type": "string",
        "description": "The unique identifier of the spec.",
        "title": "Spec Id"
      }
    },
    "query": {}
  }
