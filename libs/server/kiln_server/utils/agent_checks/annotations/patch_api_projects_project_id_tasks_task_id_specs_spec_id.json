{
  "method": "patch",
  "path": "/api/projects/{project_id}/tasks/{task_id}/specs/{spec_id}",
  "agent_policy": {
    "permission": "allow",
    "requires_approval": true,
    "approval_description": "Allow agent to edit spec? Ensure you backup your project before allowing agentic edits."
  },
  "request_body": {
    "required": true,
    "content_type": "application/json",
    "schema": {
      "properties": {
        "name": {
          "anyOf": [
            {
              "type": "string",
              "maxLength": 120,
              "minLength": 1
            },
            {
              "type": "null"
            }
          ],
          "title": "Name",
          "description": "The updated name."
        },
        "definition": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Definition",
          "description": "The updated definition."
        },
        "properties": {
          "anyOf": [
            {
              "oneOf": [
                {
                  "properties": {
                    "spec_type": {
                      "type": "string",
                      "const": "desired_behaviour",
                      "title": "Spec Type"
                    },
                    "desired_behaviour_description": {
                      "type": "string",
                      "title": "Desired Behaviour Description"
                    },
                    "correct_behaviour_examples": {
                      "type": "string",
                      "title": "Correct Behaviour Examples"
                    },
                    "incorrect_behaviour_examples": {
                      "type": "string",
                      "title": "Incorrect Behaviour Examples"
                    }
                  },
                  "type": "object",
                  "required": [
                    "spec_type",
                    "desired_behaviour_description"
                  ],
                  "title": "DesiredBehaviourProperties"
                },
                {
                  "properties": {
                    "spec_type": {
                      "type": "string",
                      "const": "issue",
                      "title": "Spec Type"
                    },
                    "issue_description": {
                      "type": "string",
                      "title": "Issue Description"
                    },
                    "issue_examples": {
                      "type": "string",
                      "title": "Issue Examples"
                    },
                    "non_issue_examples": {
                      "type": "string",
                      "title": "Non Issue Examples"
                    }
                  },
                  "type": "object",
                  "required": [
                    "spec_type",
                    "issue_description"
                  ],
                  "title": "IssueProperties"
                },
                {
                  "properties": {
                    "spec_type": {
                      "type": "string",
