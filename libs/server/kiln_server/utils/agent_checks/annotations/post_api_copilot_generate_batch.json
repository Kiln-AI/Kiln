{
  "method": "post",
  "path": "/api/copilot/generate_batch",
  "agent_policy": {
    "permission": "allow",
    "requires_approval": true,
    "approval_description": "Run Copilot batch generation?"
  },
  "request_body": {
    "required": true,
    "content_type": "application/json",
    "schema": {
      "properties": {
        "target_task_info": {
          "properties": {
            "task_prompt": {
              "type": "string",
              "title": "Task Prompt",
              "description": "The task's prompt."
            },
            "task_input_schema": {
              "type": "string",
              "title": "Task Input Schema",
              "description": "The task's input JSON schema."
            },
            "task_output_schema": {
              "type": "string",
              "title": "Task Output Schema",
              "description": "The task's output JSON schema."
            }
          },
          "type": "object",
          "required": [
            "task_prompt",
            "task_input_schema",
            "task_output_schema"
          ],
          "title": "TaskInfoApi",
          "description": "Task information for copilot API calls."
        },
        "target_specification": {
          "type": "string",
          "title": "Target Specification"
        },
        "num_samples_per_topic": {
          "type": "integer",
          "title": "Num Samples Per Topic"
        },
        "num_topics": {
          "type": "integer",
          "title": "Num Topics"
        },
        "sdg_session_config": {
          "properties": {
            "topic_generation_config": {
              "properties": {
                "task_metadata": {
                  "properties": {
                    "model_name": {
                      "type": "string",
                      "title": "Model Name",
                      "description": "The name of the AI model used."
                    },
                    "model_provider_name": {
                      "type": "string",
                      "enum": [
                        "openai",
                        "groq",
                        "amazon_bedrock",
                        "ollama",
                        "openrouter",
                        "fireworks_ai",
                        "kiln_fine_tune",
                        "kiln_custom_registry",
                        "openai_compatible",
                        "anthropic",
                        "gemini_api",
                        "azure_openai",
                        "huggingface",
                        "vertex",
                        "together_ai",
                        "siliconflow_cn",
                        "cerebras",
                        "docker_model_runner"
                      ],
                      "title": "ModelProviderName",
                      "description": "Enumeration of supported AI model providers."
                    }
                  },
                  "type": "object",
                  "required": [
                    "model_name",
                    "model_provider_name"
                  ],
                  "title": "TaskMetadataApi",
                  "description": "Metadata about the model used for a task."
                },
                "prompt": {
                  "type": "string",
                  "title": "Prompt"
                }
              },
              "type": "object",
              "required": [
                "task_metadata",
                "prompt"
              ],
              "title": "SyntheticDataGenerationStepConfigApi",
              "description": "Configuration for a synthetic data generation step."
            },
            "input_generation_config": {
              "properties": {
                "task_metadata": {
                  "properties": {
                    "model_name": {
                      "type": "string",
                      "title": "Model Name",
                      "description": "The name of the AI model used."
                    },
                    "model_provider_name": {
                      "type": "string",
                      "enum": [
                        "openai",
                        "groq",
                        "amazon_bedrock",
                        "ollama",
                        "openrouter",
                        "fireworks_ai",
                        "kiln_fine_tune",
                        "kiln_custom_registry",
                        "openai_compatible",
                        "anthropic",
                        "gemini_api",
                        "azure_openai",
                        "huggingface",
                        "vertex",
                        "together_ai",
                        "siliconflow_cn",
                        "cerebras",
                        "docker_model_runner"
                      ],
                      "title": "ModelProviderName",
                      "description": "Enumeration of supported AI model providers."
                    }
                  },
                  "type": "object",
                  "required": [
                    "model_name",
                    "model_provider_name"
                  ],
                  "title": "TaskMetadataApi",
                  "description": "Metadata about the model used for a task."
                },
                "prompt": {
                  "type": "string",
                  "title": "Prompt"
                }
              },
              "type": "object",
              "required": [
                "task_metadata",
                "prompt"
              ],
              "title": "SyntheticDataGenerationStepConfigApi",
              "description": "Configuration for a synthetic data generation step."
            },
            "output_generation_config": {
              "properties": {
                "task_metadata": {
                  "properties": {
                    "model_name": {
                      "type": "string",
                      "title": "Model Name",
                      "description": "The name of the AI model used."
                    },
                    "model_provider_name": {
                      "type": "string",
                      "enum": [
                        "openai",
                        "groq",
                        "amazon_bedrock",
                        "ollama",
                        "openrouter",
                        "fireworks_ai",
                        "kiln_fine_tune",
                        "kiln_custom_registry",
                        "openai_compatible",
                        "anthropic",
                        "gemini_api",
                        "azure_openai",
                        "huggingface",
                        "vertex",
                        "together_ai",
                        "siliconflow_cn",
                        "cerebras",
                        "docker_model_runner"
                      ],
                      "title": "ModelProviderName",
                      "description": "Enumeration of supported AI model providers."
                    }
                  },
                  "type": "object",
                  "required": [
                    "model_name",
                    "model_provider_name"
                  ],
                  "title": "TaskMetadataApi",
                  "description": "Metadata about the model used for a task."
                },
                "prompt": {
                  "type": "string",
                  "title": "Prompt"
                }
              },
              "type": "object",
              "required": [
                "task_metadata",
                "prompt"
              ],
              "title": "SyntheticDataGenerationStepConfigApi",
              "description": "Configuration for a synthetic data generation step."
            }
          },
          "type": "object",
          "required": [
            "topic_generation_config",
            "input_generation_config",
            "output_generation_config"
          ],
          "title": "SyntheticDataGenerationSessionConfigApi",
          "description": "Configuration for a synthetic data generation session"
        }
      },
      "type": "object",
      "required": [
        "target_task_info",
        "target_specification",
        "num_samples_per_topic",
        "num_topics",
        "sdg_session_config"
      ],
      "title": "GenerateBatchApiInput",
      "description": "Input for generating a batch of examples."
    }
  },
  "parameters": {
    "path": {},
    "query": {}
  }
}
