{
  "method": "patch",
  "path": "/api/projects/{project_id}/skills/{skill_id}",
  "agent_policy": {
    "permission": "allow",
    "requires_approval": true,
    "approval_description": "Allow agent to edit skill? Ensure you backup your project before allowing agentic edits."
  },
  "request_body": {
    "required": true,
    "content_type": "application/json",
    "schema": {
      "properties": {
        "is_archived": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "title": "Is Archived",
          "description": "Whether the skill is archived."
        }
      },
      "type": "object",
      "title": "SkillUpdateRequest",
      "description": "Request to update a skill."
    }
  },
  "parameters": {
    "path": {
      "project_id": {
        "type": "string",
        "description": "The unique identifier of the project.",
        "title": "Project Id"
      },
      "skill_id": {
        "type": "string",
        "description": "The unique identifier of the skill.",
        "title": "Skill Id"
      }
    },
    "query": {}
  }
}
