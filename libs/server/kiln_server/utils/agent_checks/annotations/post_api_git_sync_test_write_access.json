{
  "method": "post",
  "path": "/api/git_sync/test_write_access",
  "agent_policy": {
    "permission": "deny",
    "requires_approval": false
  },
  "request_body": {
    "required": true,
    "content_type": "application/json",
    "schema": {
      "properties": {
        "clone_path": {
          "type": "string",
          "title": "Clone Path",
          "description": "Local filesystem path of the cloned repo."
        },
        "pat_token": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Pat Token",
          "description": "Optional personal access token for authentication."
        },
        "oauth_token": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Oauth Token",
          "description": "Optional OAuth token for authentication."
        },
        "auth_mode": {
          "type": "string",
          "enum": [
            "system_keys",
            "pat_token",
            "github_oauth"
          ],
          "title": "Auth Mode",
          "description": "Auth mode: 'system_keys', 'pat_token', or 'github_oauth'.",
          "default": "system_keys"
        }
      },
      "type": "object",
      "required": [
        "clone_path"
      ],
      "title": "TestWriteAccessRequest",
      "description": "Request to test push/write access to a cloned repo's remote."
    }
  },
  "parameters": {
    "path": {},
    "query": {}
  }
}
