# Kiln Web UI — Developer Environment Variables
#
# Copy to .env and uncomment as needed. These are optional; defaults are fine for normal use.
# Variables with the PUBLIC_ prefix are available client-side via $env/dynamic/public.

# Kinde account domain and client ID for Kiln Copilot.
# PUBLIC_KINDE_ACCOUNT_DOMAIN=
# PUBLIC_KINDE_ACCOUNT_CLIENT_ID=

# Background Jobs UI — set to "true" to show the Jobs entry in the sidebar and
# enable the jobs dialog. When unset or any other value, the feature is hidden.
# PUBLIC_ENABLE_JOBS=true

# Sentry — set the DSN to enable client-side error reporting. Unset = no-op.
# VITE_KILN_SENTRY_DSN=https://...@o.../...
